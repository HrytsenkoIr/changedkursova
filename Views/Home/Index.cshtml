@using System.Linq
@model IEnumerable<OnlineStoreSystem.EFModels.Order>

@{
    ViewData["Title"] = "Головна";
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="text-center fade-in">
        <h1 class="display-4 mb-4">
            Управління базою даних інтернет магазину відьмацьких товарів
        </h1>

        <!-- СТАТИСТИКА -->
        <div class="row mt-5">
            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h2>@ViewBag.TotalProducts</h2>
                        <p>Товарів</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h2>@ViewBag.TotalCustomers</h2>
                        <p>Клієнтів</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h2>@ViewBag.TotalOrders</h2>
                        <p>Замовлень</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h2>@ViewBag.TotalRevenue ₴</h2>
                        <p>Виручка</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- ТАБЛИЦІ -->
        <div class="row mt-4">
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-header">
                        <h5>Топ товарів</h5>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.BestSellers != null && ViewBag.BestSellers.Rows.Count > 0)
                        {
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Продано</th>
                                        <th>Виручка</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (System.Data.DataRow row in ViewBag.BestSellers.Rows)
                                    {
                                        <tr>
                                            <td>@row["Name"]</td>
                                            <td>@row["TotalSold"]</td>
                                            <td>@row["TotalRevenue"] ₴</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Немає даних про продажі</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-header">
                        <h5>Останні замовлення</h5>
                    </div>
                    <div class="card-body">
                        @if (Model != null && Model.Any())
                        {
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Клієнт</th>
                                        <th>Дата</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>#@order.OrderId</td>
                                            <td>@order.Customer?.Name</td>
                                            <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                <span class="badge @GetStatusBadge(order.Status)">
                                                    @order.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Немає останніх замовлень</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <img src="~/images/please-login.png" alt="Лише для авторизованих користувачів" class="img-fluid" style="max-width: 400px;">
        <p class="mt-3 text-muted">Будь ласка, увійдіть у систему, щоб переглянути статистику.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-2">Увійти</a>
    </div>
}

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Paid" => "bg-success",
            "Pending" => "bg-warning",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
