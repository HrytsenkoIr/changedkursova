@{
    ViewData["Title"] = "Панель керування";
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="container py-4">
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-dark">Детальна статистика</h1>
            <p class="lead text-muted">Аналітика продажів та категорій магазину</p>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary p-4 d-flex align-items-center justify-content-center" style="width: 100px;">
                            <i class="bi bi-cart-check text-white fs-1"></i>
                        </div>
                        <div class="card-body">
                            <h3 class="card-title fw-bold mb-0">@ViewBag.MonthlyOrders</h3>
                            <p class="text-muted mb-0">Замовлень за останні 30 днів</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="d-flex align-items-center">
                        <div class="bg-success p-4 d-flex align-items-center justify-content-center" style="width: 100px;">
                            <i class="bi bi-cash-stack text-white fs-1"></i>
                        </div>
                        <div class="card-body">
                            <h3 class="card-title fw-bold mb-0">@string.Format("{0:N2} ₴", ViewBag.MonthlyRevenue)</h3>
                            <p class="text-muted mb-0">Виручка за місяць</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Таблиця категорій залишаємо як є -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="mb-0 fw-bold"><i class="bi bi-trophy text-warning me-2"></i>Найпопулярніші категорії</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Категорія</th>
                                <th class="text-center">Продано одиниць</th>
                                <th style="width: 30%">Популярність</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.PopularCategories != null)
                            {
                                var categories = (IEnumerable<dynamic>)ViewBag.PopularCategories;
                                var maxSales = categories.Any() ? categories.Max(c => (int)c.SalesCount) : 1;

                                foreach (var category in categories)
                                {
                                    int percentage = (int)((double)category.SalesCount / maxSales * 100);
                                    
                                    <tr>
                                        <td class="ps-4 fw-semibold">@category.Category</td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border px-3">@category.SalesCount шт.</span>
                                        </td>
                                        <td class="pe-4">
                                            <div class="progress" style="height: 8px;">
                                                <div class="progress-bar bg-info" role="progressbar" 
                                                     style="width: @percentage%" 
                                                     aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5 text-muted">
                                        <i class="bi bi-exclamation-circle d-block fs-2 mb-2"></i>
                                        Дані про категорії відсутні
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                <i class="bi bi-arrow-left me-2"></i> На головну сторінку
            </a>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <img src="~/images/please-login.png" alt="Лише для авторизованих користувачів" class="img-fluid" style="max-width: 400px;">
        <p class="mt-3 text-muted">Будь ласка, увійдіть у систему, щоб переглянути панель керування.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-2">Увійти</a>
    </div>
}
