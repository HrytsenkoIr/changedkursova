@using System.Linq
@model IEnumerable<OnlineStoreSystem.EFModels.Product>
@{
    ViewData["Title"] = "Товари";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Список товарів</h1>
    <a asp-action="Create" class="btn btn-success">Додати товар</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <input type="number" name="minPrice" class="form-control" placeholder="Мінімальна ціна" value="@ViewBag.MinPrice">
            </div>
            <div class="col-md-3">
                <input type="number" name="maxPrice" class="form-control" placeholder="Максимальна ціна" value="@ViewBag.MaxPrice">
            </div>
            <div class="col-md-4">
                <select name="categoryId" class="form-control" asp-items="ViewBag.Categories">
                    <option value="">Всі категорії</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"> Фільтрувати</button>
            </div>
        </form>
    </div>
</div>

<!-- Таблиця товарів -->
<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Назва</th>
                <th>Опис</th>
                <th>Ціна</th>
                <th>На складі</th>
                <th>Статус</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>
                        <strong>@item.Name</strong>
                        @if (!string.IsNullOrEmpty(item.Category?.Name))
                        {
                            <br>
                            <small class="text-muted">@item.Category.Name</small>
                        }
                    </td>
                    <td>@(item.Description?.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</td>
                    <td>
                        <strong>@item.Price.ToString("C")</strong>
                        @if (item.DiscountedPrice.HasValue)
                        {
                            <br>
                            <small class="text-success">
                                Знижка: @item.DiscountedPrice.Value.ToString("C")
                            </small>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.Stock > 10 ? "bg-success" : item.Stock > 0 ? "bg-warning" : "bg-danger")">
                            @item.Stock шт.
                        </span>
                    </td>
                    <td>
                        <span class="badge @GetStatusBadge(item.Status.ToString())">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-info">Переглянути</a>
                            <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">Редагувати</a>
                            <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger">Видалити</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        Товари не знайдено. <a asp-action="Create">Додати перший товар</a>
    </div>
}

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Active" => "bg-success",
            "Available" => "bg-primary",
            "OutOfStock" => "bg-warning",
            "Discontinued" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}