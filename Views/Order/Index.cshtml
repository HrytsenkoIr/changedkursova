@using System.Linq
@model IEnumerable<OnlineStoreSystem.EFModels.Order>

@{
    ViewData["Title"] = "Замовлення";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Замовлення</h1>
    <a asp-action="Create" class="btn btn-success">Створити замовлення</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <select name="status" class="form-control" asp-items="ViewBag.OrderStatuses">
                    <option value="">Всі статуси</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="fromDate" class="form-control" placeholder="З дати">
            </div>
            <div class="col-md-2">
                <input type="date" name="toDate" class="form-control" placeholder="По дату">
            </div>
            <div class="col-md-3">
                <input type="number" name="minTotalAmount" class="form-control" placeholder="Мінімальна сума">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Фільтрувати</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Клієнт</th>
                <th>Дата</th>
                <th>Статус</th>
                <th>Сума</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                var totalAmount = order.OrderItems?.Sum(oi => oi.Price * oi.Amount) ?? 0;
                
                <tr>
                    <td>
                        <strong>#@order.OrderId</strong>
                    </td>
                    <td>
                        @order.Customer?.Name
                        <br>
                        <small class="text-muted">@order.Customer?.Email</small>
                    </td>
                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <span class="badge @GetStatusBadge(order.Status)">
                            @order.Status
                        </span>
                    </td>
                    <td>
                        <strong>@totalAmount.ToString("C")</strong>
                        <br>
                        <small>@order.OrderItems?.Count() товарів</small>
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-info">Переглянути</a>
                            <a asp-action="Edit" asp-route-id="@order.OrderId" class="btn btn-sm btn-warning">Редагувати</a>
                            <a asp-action="Delete" asp-route-id="@order.OrderId" class="btn btn-sm btn-danger">Видалити</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        Замовлення не знайдено. <a asp-action="Create">Створити перше замовлення</a>
    </div>
}

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Paid" => "bg-success",
            "Pending" => "bg-warning",
            "Cancelled" => "bg-danger",
            "Payment on Delivery" => "bg-info",
            "Refunded" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }
}