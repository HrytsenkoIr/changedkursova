@model OnlineStoreSystem.ViewModels.OrderEditViewModel

@{
    ViewData["Title"] = $"Редагування замовлення #{Model.OrderId}";
    var totalAmount = (Model.ExistingOrderItems?.Sum(oi => oi.Price * oi.Amount) ?? 0)
                      + (Model.NewOrderItems?.Sum(oi => oi.Price * oi.Amount) ?? 0);
    var canAccess = User.IsInRole("Admin");
}

@if (canAccess)
{
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">Редагувати замовлення @Model.OrderId</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="OrderId" />

                        <!-- Інформація про клієнта -->
                        <h5 class="mb-3">Інформація про клієнта</h5>
                        <div class="mb-3">
                            <label asp-for="CustomerId" class="form-label">Клієнт *</label>
                            <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.Customers">
                                <option value="">-- Оберіть клієнта --</option>
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>

                        <!-- Деталі замовлення -->
                        <h5 class="mb-3 mt-4">Деталі замовлення</h5>
                        <div class="mb-3">
                            <label asp-for="OrderDate" class="form-label">Дата замовлення</label>
                            <input type="datetime-local"
       class="form-control"
       name="OrderDate"
       value="@Model.OrderDate.ToString("yyyy-MM-ddTHH:mm")" />

                            <span asp-validation-for="OrderDate" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Статус</label>
                            <select asp-for="Status" class="form-control" asp-items="ViewBag.OrderStatuses">
                                <option value="">Оберіть статус</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Спосіб оплати</label>
                            <select asp-for="PaymentMethod" class="form-control" asp-items="ViewBag.PaymentMethods">
                                <option value="">-- Оберіть спосіб оплати --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DeliveryType" class="form-label">Спосіб доставки</label>
                            <select asp-for="DeliveryType" class="form-control" asp-items="ViewBag.DeliveryTypes">
                                <option value="">Оберіть спосіб доставки</option>
                            </select>
                        </div>

                        <!-- Існуючі товари -->
                        <h5 class="mb-3 mt-4">Існуючі товари</h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Кількість</th>
                                        <th>Ціна</th>
                                        <th>Сума</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.ExistingOrderItems.Count; i++)
                                    {
                                        <tr>
                                            <td>@Model.ExistingOrderItems[i].ProductName</td>
                                            <td>
                                                <input type="number" asp-for="ExistingOrderItems[@i].Amount" class="form-control" min="1" />
                                                <input type="hidden" asp-for="ExistingOrderItems[@i].ProductId" />
                                            </td>
                                            <td>@Model.ExistingOrderItems[i].Price.ToString("C")</td>
                                            <td>@(Model.ExistingOrderItems[i].Price * Model.ExistingOrderItems[i].Amount).ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Нові товари -->
                        <h5 class="mb-3 mt-4">Додати нові товари</h5>
                        <div class="table-responsive">
                            <table class="table table-sm" id="newOrderItemsTable">
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Кількість</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                            <button type="button" class="btn btn-outline-primary mt-2" id="addProductBtn">Додати товар</button>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-secondary">Скасувати</a>
                            <button type="submit" class="btn btn-warning">Зберегти зміни</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger">
        У вас немає доступу до цієї сторінки.
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var orderDateInput = document.getElementById('OrderDate');
            if (orderDateInput && orderDateInput.value) {
                var date = new Date(orderDateInput.value);
                orderDateInput.value = date.toISOString().slice(0, 16);
            }

            var addBtn = document.getElementById('addProductBtn');
            var table = document.getElementById('newOrderItemsTable').getElementsByTagName('tbody')[0];
            var newIndex = 0;

            addBtn.addEventListener('click', function () {
                var row = document.createElement('tr');
                row.innerHTML = `
                    <td>
                        <select name="NewOrderItems[${newIndex}].ProductId" class="form-control">
                            <option value="">-- Оберіть товар --</option>
                            @foreach (var p in ViewBag.Products as SelectList)
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input type="number" name="NewOrderItems[${newIndex}].Amount" value="1" min="1" class="form-control" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger removeBtn">x</button>
                    </td>
                `;
                table.appendChild(row);

                row.querySelector('.removeBtn').addEventListener('click', function () {
                    row.remove();
                });

                newIndex++;
            });
        });
    </script>
}
