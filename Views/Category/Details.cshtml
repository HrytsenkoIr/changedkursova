@model OnlineStoreSystem.EFModels.Category
@{
    ViewData["Title"] = $"Категорія: {Model.Name}";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Інформація про категорію</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">ID:</dt>
                    <dd class="col-sm-9">@Model.CategoryId</dd>

                    <dt class="col-sm-3">Назва:</dt>
                    <dd class="col-sm-9">
                        <strong>@Model.Name</strong>
                    </dd>

                    <dt class="col-sm-3">Кількість продуктів:</dt>
                    <dd class="col-sm-9">
                        <strong>@Model.Products.Count</strong>
                    </dd>
                </dl>
            </div>
            <div class="card-footer">
                <div class="btn-group">
                    <a asp-action="Edit"
                       asp-route-id="@Model.CategoryId"
                       class="btn btn-warning">
                        Редагувати
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@Model.CategoryId"
                       class="btn btn-danger">
                        Видалити
                    </a>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        ← Назад до списку
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-light">
                <h5>Продукти у категорії</h5>
            </div>
            <div class="card-body">
                @if (Model.Products != null && Model.Products.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var product in Model.Products)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@product.Name</span>
                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@product.ProductId"
                                   class="btn btn-sm btn-info">
                                    👁️
                                </a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <span class="text-muted">Продуктів немає</span>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header bg-light">
                <h5>Дії</h5>
            </div>
            <div class="card-body">
                <a asp-controller="Product"
                   asp-action="Create"
                   asp-route-categoryId="@Model.CategoryId"
                   class="btn btn-primary w-100">
                    Додати продукт у категорію
                </a>
            </div>
        </div>
    </div>
</div>
